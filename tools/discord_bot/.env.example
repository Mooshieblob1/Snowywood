# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Discord ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_BOT_TOKEN=
# Your server (guild) ID. Optional but recommended: makes slash commands register instantly.
DISCORD_GUILD_ID=
# Channel IDs (enable Developer Mode in Discord, right-click a channel -> Copy ID)
ANNOUNCE_CHANNEL_ID=
OOC_CHANNEL_ID=
AHELP_CHANNEL_ID=

# --- Game (BYOND world topic) ---
GAME_HOST=127.0.0.1
GAME_PORT=1337
# Must match COMMS_KEY in config/comms.txt
GAME_COMMS_KEY=

# --- Inbound HTTP ingest (game -> bot) ---
BOT_INGEST_HOST=127.0.0.1
BOT_INGEST_PORT=5000
# Must match DISCORD_BOT_SECRET in config/secrets.txt. Generate: openssl rand -hex 32
BOT_INGEST_SECRET=

# --- Behaviour ---
PRESENCE_INTERVAL=60
